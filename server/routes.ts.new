// ── Job Assignments (the drag-and-drop core) ────────────────────
api.get("/assignments", async (c) => {
  const jobId = c.req.query("jobId");
  const activeOnly = c.req.query("active") !== "false";

  let condition = activeOnly ? eq(jobAssignments.isActive, true) : undefined;
  if (jobId) {
    const jid = parseInt(jobId);
    condition = activeOnly
      ? and(eq(jobAssignments.jobId, jid), eq(jobAssignments.isActive, true))
      : eq(jobAssignments.jobId, jid);
  }

  const rows = await db
    .select({
      id: jobAssignments.id,
      jobId: jobAssignments.jobId,
      employeeId: jobAssignments.employeeId,
      role: jobAssignments.role,
      billRate: jobAssignments.billRate,
      isActive: jobAssignments.isActive,
      assignedAt: jobAssignments.assignedAt,
      employeeFirstName: employees.firstName,
      employeeLastName: employees.lastName,
      employeeNumber: employees.employeeNumber,
      classificationName: classifications.name,
      classificationColor: classifications.color,
      department: classifications.department,
    })
    .from(jobAssignments)
    .leftJoin(employees, eq(jobAssignments.employeeId, employees.id))
    .leftJoin(classifications, eq(employees.classificationId, classifications.id))
    .where(condition);

  return c.json(rows);
});

// Assign employee to job (drag to job)
api.post("/assignments", requireRole("admin", "pm"), async (c) => {
  const { jobId, employeeId, role, billRate } = await c.req.json();

  // Check if assignment already exists
  const [existing] = await db
    .select()
    .from(jobAssignments)
    .where(and(eq(jobAssignments.jobId, jobId), eq(jobAssignments.employeeId, employeeId)))
    .limit(1);

  if (existing) {
    // Re-activate if it was deactivated
    const [row] = await db
      .update(jobAssignments)
      .set({ isActive: true, role, billRate, assignedAt: new Date().toISOString() })
      .where(eq(jobAssignments.id, existing.id))
      .returning();
    return c.json(row);
  }

  const [row] = await db
    .insert(jobAssignments)
    .values({ jobId, employeeId, role, billRate })
    .returning();
  return c.json(row, 201);
});

// Unassign employee (drag back to bench)
api.delete("/assignments/:id", requireRole("admin", "pm"), async (c) => {
  const id = parseInt(c.req.param("id"));
  await db.update(jobAssignments).set({ isActive: false }).where(eq(jobAssignments.id, id));
  return c.json({ ok: true });
});

// Move employee between jobs
api.post("/assignments/move", requireRole("admin", "pm"), async (c) => {
  const { employeeId, fromJobId, toJobId } = await c.req.json();

  // Deactivate old assignment
  await db
    .update(jobAssignments)
    .set({ isActive: false })
    .where(and(eq(jobAssignments.employeeId, employeeId), eq(jobAssignments.jobId, fromJobId)));

  // Create or reactivate new assignment
  const [existing] = await db
    .select()
    .from(jobAssignments)
    .where(and(eq(jobAssignments.jobId, toJobId), eq(jobAssignments.employeeId, employeeId)))
    .limit(1);

  if (existing) {
    const [row] = await db
      .update(jobAssignments)
      .set({ isActive: true, assignedAt: new Date().toISOString() })
      .where(eq(jobAssignments.id, existing.id))
      .returning();
    return c.json(row);
  }

  const [row] = await db
    .insert(jobAssignments)
    .values({ jobId: toJobId, employeeId })
    .returning();
  return c.json(row, 201);
});

// ── Workforce Board aggregate (single call for the board) ───────
api.get("/workforce-board", async (c) => {
  const companyId = getCompanyId(c);
  // Get all active employees with classifications + photo
  const allEmployees = await db
    .select({
      id: employees.id,
      employeeNumber: employees.employeeNumber,
      firstName: employees.firstName,
      lastName: employees.lastName,
      classificationId: employees.classificationId,
      classificationName: classifications.name,
      classificationColor: classifications.color,
      department: classifications.department,
      hasLicense: classifications.hasLicense,
      status: employees.status,
      photoUrl: employees.photoUrl,
    })
    .from(employees)
    .leftJoin(classifications, eq(employees.classificationId, classifications.id))
    .where(and(eq(employees.companyId, companyId), eq(employees.status, "active")))
    .orderBy(classifications.name, employees.lastName);

  // Get all active assignments
  const activeAssignments = await db
    .select()
    .from(jobAssignments)
    .where(eq(jobAssignments.isActive, true));

  // Get active/planning jobs with budgets and jurisdictions (only showOnBoard)
  const activeJobs = await db
    .select({
      id: jobs.id,
      jobNumber: jobs.jobNumber,
      name: jobs.name,
      address: jobs.address,
      jurisdictionId: jobs.jurisdictionId,
      gcContact: jobs.gcContact,
      status: jobs.status,
      startDate: jobs.startDate,
      endDate: jobs.endDate,
      scopeOfWork: jobs.scopeOfWork,
      originalContract: jobs.originalContract,
      currentContract: jobs.currentContract,
      showOnBoard: jobs.showOnBoard,
      createdAt: jobs.createdAt,
      updatedAt: jobs.updatedAt,
      jurisdictionName: jurisdictions.name,
    })
    .from(jobs)
    .leftJoin(jurisdictions, eq(jobs.jurisdictionId, jurisdictions.id))
    .where(and(eq(jobs.companyId, companyId), sql`${jobs.status} IN ('planning', 'active') AND ${jobs.showOnBoard} = 1`))
    .orderBy(jobs.jobNumber);

  const budgets = await db.select().from(jobBudgets);

  // Get all jurisdiction rates for quick lookup — build a map keyed by "jurId:classId"
  const allJurisdictionRates = await db.select().from(jurisdictionRates).where(eq(jurisdictionRates.companyId, companyId));
  const rateMap = new Map<string, { hourlyRate: number; totalCostRate: number }>();
  for (const r of allJurisdictionRates) {
    rateMap.set(`${Number(r.jurisdictionId)}:${Number(r.classificationId)}`, {
      hourlyRate: r.hourlyRate,
      totalCostRate: r.totalCostRate,
    });
  }

  // Build the board data
  const assignedEmployeeIds = new Set(activeAssignments.map((a) => a.employeeId));
  const bench = allEmployees.filter((e) => !assignedEmployeeIds.has(e.id));

  const jobCards = activeJobs.map((job) => {
    const jobAssigns = activeAssignments.filter((a) => a.jobId === job.id);
    const crew = jobAssigns.map((a) => {
      const emp = allEmployees.find((e) => e.id === a.employeeId);
      if (!emp) return null;

      // Look up jurisdiction-specific rate: job jurisdiction + employee classification
      let effectiveRate = 0;
      let effectiveHourly = 0;
      if (job.jurisdictionId && emp.classificationId) {
        const key = `${Number(job.jurisdictionId)}:${Number(emp.classificationId)}`;
        const jRate = rateMap.get(key);
        if (jRate) {
          effectiveHourly = jRate.hourlyRate;
          effectiveRate = jRate.totalCostRate;
        }
      }

      return {
        ...emp,
        assignmentId: a.id,
        role: a.role,
        billRate: a.billRate,
        effectiveHourlyRate: effectiveHourly,
        effectiveCostRate: effectiveRate,
      };
    }).filter(Boolean);

    const jobBudgetData = budgets.filter((b) => b.jobId === job.id);
    const totalBudget = jobBudgetData.reduce((s, b) => s + (b.currentBudget || 0), 0);
    const dailyLaborCost = crew.reduce((s, e: any) => s + (e.effectiveCostRate || 0) * 8, 0);
    const weeklyLaborCost = crew.reduce((s, e: any) => s + (e.effectiveCostRate || 0) * 40, 0);
    const compositeHourlyRate = crew.length > 0
      ? crew.reduce((s, e: any) => s + (e.effectiveHourlyRate || 0), 0) / crew.length
      : 0;

    // Licensed to non-licensed ratio
    const licensedCount = crew.filter((e: any) => e.hasLicense).length;
    const nonLicensedCount = crew.length - licensedCount;
    let licenseRatio = { licensed: 0, perNonLicensed: 0 };
    if (crew.length > 0) {
      if (licensedCount === 0) {
        licenseRatio = { licensed: 0, perNonLicensed: nonLicensedCount };
      } else {
        // Express as 1/X where X = non-licensed per licensed (up to 2 decimals)
        const ratio = nonLicensedCount / licensedCount;
        const rounded = Math.round(ratio * 100) / 100;
        licenseRatio = { licensed: 1, perNonLicensed: rounded };
      }
    }

    return {
      ...job,
      crew,
      crewCount: crew.length,
      budgets: jobBudgetData,
      totalBudget,
      dailyLaborCost,
      weeklyLaborCost,
      compositeHourlyRate,
      licenseRatio,
    };
  });

  return c.json({ bench, jobs: jobCards });
});

