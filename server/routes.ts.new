import { Hono } from "hono";
import { db } from "./db.js";
import {
  employees, classifications, jobs, jobBudgets, jobCosts,
  jobAssignments, subcontracts, certifications, assets,
  employeeNotes, users, jurisdictions, jurisdictionRates, settings,
  companies
} from "../shared/schema.js";
import { eq, and, sql, desc } from "drizzle-orm";
import { requireAuth, requireRole, requireSuperAdmin } from "./auth.js";
import { getCompanyId } from "./tenant.js";
import bcrypt from "bcryptjs";
import { mkdirSync, writeFileSync, readdirSync, unlinkSync } from "fs";
import { dirname } from "path";

const api = new Hono();

// ── Public Settings (no auth — needed on login page) ────────────
api.get("/settings", async (c) => {
  const cid = parseInt(c.req.query("companyId") || "1");
  const rows = await db.select().from(settings).where(eq(settings.companyId, cid));
  const obj: Record<string, string> = {};
  for (const r of rows) obj[r.key] = r.value;
  return c.json(obj);
});

// All remaining API routes require auth
api.use("/*", requireAuth);

// ── Classifications ─────────────────────────────────────────────
api.get("/classifications", async (c) => {
  const companyId = getCompanyId(c);
  const rows = await db.select().from(classifications).where(eq(classifications.companyId, companyId)).orderBy(classifications.name);
  return c.json(rows);
});

api.post("/classifications", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const data = await c.req.json();
  const [row] = await db.insert(classifications).values({ ...data, companyId }).returning();
  return c.json(row, 201);
});

api.put("/classifications/:id", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const data = await c.req.json();
  const [row] = await db.update(classifications).set(data).where(and(eq(classifications.id, id), eq(classifications.companyId, companyId))).returning();
  return c.json(row);
});

// ── Employees ───────────────────────────────────────────────────
api.get("/employees", async (c) => {
  const companyId = getCompanyId(c);
  const status = c.req.query("status");
  const rows = await db
    .select({
      id: employees.id,
      employeeNumber: employees.employeeNumber,
      firstName: employees.firstName,
      lastName: employees.lastName,
      classificationId: employees.classificationId,
      status: employees.status,
      phone: employees.phone,
      pePhone: employees.pePhone,
      personalEmail: employees.personalEmail,
      workEmail: employees.workEmail,
      address: employees.address,
      emergencyContactName: employees.emergencyContactName,
      emergencyContactPhone: employees.emergencyContactPhone,
      dateOfHire: employees.dateOfHire,
      dateOfBirth: employees.dateOfBirth,
      placeOfBirth: employees.placeOfBirth,
      shirtSize: employees.shirtSize,
      jacketSize: employees.jacketSize,
      elecLicense: employees.elecLicense,
      dlNumber: employees.dlNumber,
      dlState: employees.dlState,
      dlExpiration: employees.dlExpiration,
      backgroundCheck: employees.backgroundCheck,
      backgroundCheckDate: employees.backgroundCheckDate,
      reasonForLeaving: employees.reasonForLeaving,
      photoUrl: employees.photoUrl,
      notes: employees.notes,
      createdAt: employees.createdAt,
      updatedAt: employees.updatedAt,
      classificationName: classifications.name,
      classificationColor: classifications.color,
      department: classifications.department,
    })
    .from(employees)
    .leftJoin(classifications, eq(employees.classificationId, classifications.id))
    .where(status ? and(eq(employees.companyId, companyId), eq(employees.status, status as "active" | "inactive")) : eq(employees.companyId, companyId))
    .orderBy(employees.lastName, employees.firstName);

  return c.json(rows);
});

api.get("/employees/:id", async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const [row] = await db
    .select()
    .from(employees)
    .leftJoin(classifications, eq(employees.classificationId, classifications.id))
    .where(and(eq(employees.id, id), eq(employees.companyId, companyId)))
    .limit(1);
  if (!row) return c.json({ error: "Not found" }, 404);
  return c.json({ ...row.employees, classification: row.classifications });
});

api.post("/employees", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const data = await c.req.json();
  const [row] = await db.insert(employees).values({ ...data, companyId }).returning();
  return c.json(row, 201);
});

api.put("/employees/:id", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const data = await c.req.json();
  data.updatedAt = new Date().toISOString();
  const [row] = await db.update(employees).set(data).where(and(eq(employees.id, id), eq(employees.companyId, companyId))).returning();
  return c.json(row);
});

// Upload employee photo
api.post("/employees/:id/photo", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const body = await c.req.parseBody();
  const file = body["photo"];

  if (!file || typeof file === "string") {
    return c.json({ error: "No photo file provided" }, 400);
  }

  // Save to persistent data directory
  const ext = file.name?.split(".").pop()?.toLowerCase() || "jpg";
  const allowed = ["jpg", "jpeg", "png", "webp"];
  if (!allowed.includes(ext)) {
    return c.json({ error: "Only jpg, png, webp allowed" }, 400);
  }

  const dataDir = process.env.DB_PATH ? dirname(process.env.DB_PATH) : "./data";
  const photosDir = `${dataDir}/photos`;
  mkdirSync(photosDir, { recursive: true });

  // Remove old photos for this employee
  try {
    const existing = readdirSync(photosDir).filter(f => f.startsWith(`emp-${id}-`) || f === `emp-${id}.${ext}`);
    for (const old of existing) unlinkSync(`${photosDir}/${old}`);
  } catch {}

  const ts = Date.now();
  const filename = `emp-${id}-${ts}.${ext}`;
  const filepath = `${photosDir}/${filename}`;
  const buffer = await file.arrayBuffer();
  writeFileSync(filepath, Buffer.from(buffer));

  const photoUrl = `/api/photos/${filename}`;
  await db.update(employees).set({ photoUrl, updatedAt: new Date().toISOString() }).where(and(eq(employees.id, id), eq(employees.companyId, companyId)));

  return c.json({ photoUrl });
});

api.delete("/employees/:id", requireRole("admin"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  await db.delete(employees).where(and(eq(employees.id, id), eq(employees.companyId, companyId)));
  return c.json({ ok: true });
});

// ── Jobs ────────────────────────────────────────────────────────
api.get("/jobs", async (c) => {
  const companyId = getCompanyId(c);
  const status = c.req.query("status");
  const condition = status ? and(eq(jobs.companyId, companyId), eq(jobs.status, status as any)) : eq(jobs.companyId, companyId);
  const rows = await db.select().from(jobs).where(condition).orderBy(jobs.jobNumber);
  return c.json(rows);
});

api.get("/jobs/:id", async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const [job] = await db.select().from(jobs).where(and(eq(jobs.id, id), eq(jobs.companyId, companyId))).limit(1);
  if (!job) return c.json({ error: "Not found" }, 404);

  const budgets = await db.select().from(jobBudgets).where(eq(jobBudgets.jobId, id));
  const costs = await db.select().from(jobCosts).where(eq(jobCosts.jobId, id)).orderBy(desc(jobCosts.dateRecorded));
  const subs = await db.select().from(subcontracts).where(eq(subcontracts.jobId, id));

  return c.json({ ...job, budgets, costs, subcontracts: subs });
});

api.post("/jobs", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const data = await c.req.json();
  const [row] = await db.insert(jobs).values({ ...data, companyId }).returning();

  // Auto-create budget categories
  const categories = ["labor", "material", "equipment", "general", "subcontract"] as const;
  for (const cat of categories) {
    await db.insert(jobBudgets).values({ jobId: row.id, category: cat });
  }

  return c.json(row, 201);
});

api.put("/jobs/:id", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const data = await c.req.json();
  data.updatedAt = new Date().toISOString();
  // Ensure jurisdictionId is stored as integer or null (not string "null")
  if (data.jurisdictionId !== undefined) {
    data.jurisdictionId = data.jurisdictionId ? parseInt(data.jurisdictionId) : null;
  }
  const [row] = await db.update(jobs).set(data).where(and(eq(jobs.id, id), eq(jobs.companyId, companyId))).returning();
  return c.json(row);
});

