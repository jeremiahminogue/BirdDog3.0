// Bulk set rates for a jurisdiction (set all classifications at once)
api.post("/jurisdictions/:id/rates/bulk", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const jurisdictionId = parseInt(c.req.param("id"));
  const { rates } = await c.req.json(); // [{ classificationId, hourlyRate, totalCostRate }]
  const results = [];
  for (const r of rates) {
    // Upsert: delete existing then insert
    await db.delete(jurisdictionRates).where(
      and(eq(jurisdictionRates.jurisdictionId, jurisdictionId), eq(jurisdictionRates.classificationId, r.classificationId), eq(jurisdictionRates.companyId, companyId))
    );
    const [row] = await db.insert(jurisdictionRates).values({
      jurisdictionId,
      classificationId: r.classificationId,
      hourlyRate: r.hourlyRate,
      totalCostRate: r.totalCostRate,
      effectiveDate: r.effectiveDate || null,
      companyId,
    }).returning();
    results.push(row);
  }
  return c.json(results);
});

// Lookup rate for a specific jurisdiction + classification
api.get("/jurisdiction-rate-lookup", async (c) => {
  const companyId = getCompanyId(c);
  const jurisdictionId = parseInt(c.req.query("jurisdictionId") || "0");
  const classificationId = parseInt(c.req.query("classificationId") || "0");
  if (!jurisdictionId || !classificationId) return c.json({ error: "Both jurisdictionId and classificationId required" }, 400);

  const [rate] = await db
    .select()
    .from(jurisdictionRates)
    .where(and(eq(jurisdictionRates.jurisdictionId, jurisdictionId), eq(jurisdictionRates.classificationId, classificationId), eq(jurisdictionRates.companyId, companyId)))
    .limit(1);
  return c.json(rate || null);
});

// ── Assets / Tools ───────────────────────────────────────────────
api.get("/assets", async (c) => {
  const companyId = getCompanyId(c);
  const type = c.req.query("type");
  const status = c.req.query("status");
  const assignedTo = c.req.query("assignedTo");

  let query = db
    .select({
      id: assets.id,
      type: assets.type,
      category: assets.category,
      description: assets.description,
      manufacturer: assets.manufacturer,
      model: assets.model,
      serialNumber: assets.serialNumber,
      identifier: assets.identifier,
      assignedToEmployee: assets.assignedToEmployee,
      assignedToJob: assets.assignedToJob,
      status: assets.status,
      condition: assets.condition,
      purchaseDate: assets.purchaseDate,
      purchaseCost: assets.purchaseCost,
      warrantyExpires: assets.warrantyExpires,
      photoUrl: assets.photoUrl,
      notes: assets.notes,
      createdAt: assets.createdAt,
      updatedAt: assets.updatedAt,
      employeeFirstName: employees.firstName,
      employeeLastName: employees.lastName,
      employeeNumber: employees.employeeNumber,
      jobName: jobs.name,
      jobNumber: jobs.jobNumber,
    })
    .from(assets)
    .leftJoin(employees, eq(assets.assignedToEmployee, employees.id))
    .leftJoin(jobs, eq(assets.assignedToJob, jobs.id));

  const conditions: any[] = [eq(assets.companyId, companyId)];
  if (type) conditions.push(eq(assets.type, type as any));
  if (status) conditions.push(eq(assets.status, status as any));
  if (assignedTo) conditions.push(eq(assets.assignedToEmployee, parseInt(assignedTo)));

  const rows = conditions.length > 0
    ? await query.where(and(...conditions)).orderBy(assets.description)
    : await query.orderBy(assets.description);

  return c.json(rows);
});

api.get("/assets/:id", async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const [row] = await db
    .select()
    .from(assets)
    .leftJoin(employees, eq(assets.assignedToEmployee, employees.id))
    .leftJoin(jobs, eq(assets.assignedToJob, jobs.id))
    .where(and(eq(assets.id, id), eq(assets.companyId, companyId)))
    .limit(1);
  if (!row) return c.json({ error: "Not found" }, 404);
  return c.json({ ...row.assets, employee: row.employees, job: row.jobs });
});

api.post("/assets", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const data = await c.req.json();
  if (data.assignedToEmployee) data.assignedToEmployee = parseInt(data.assignedToEmployee) || null;
  if (data.assignedToJob) data.assignedToJob = parseInt(data.assignedToJob) || null;
  if (data.purchaseCost) data.purchaseCost = parseFloat(data.purchaseCost) || null;
  const [row] = await db.insert(assets).values({ ...data, companyId }).returning();
  return c.json(row, 201);
});

api.put("/assets/:id", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const data = await c.req.json();
  data.updatedAt = new Date().toISOString();
  if (data.assignedToEmployee !== undefined) data.assignedToEmployee = data.assignedToEmployee ? parseInt(data.assignedToEmployee) : null;
  if (data.assignedToJob !== undefined) data.assignedToJob = data.assignedToJob ? parseInt(data.assignedToJob) : null;
  if (data.purchaseCost !== undefined) data.purchaseCost = data.purchaseCost ? parseFloat(data.purchaseCost) : null;
  const [row] = await db.update(assets).set(data).where(and(eq(assets.id, id), eq(assets.companyId, companyId))).returning();
  return c.json(row);
});

api.post("/assets/:id/photo", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const body = await c.req.parseBody();
  const file = body["photo"];

  if (!file || typeof file === "string") {
    return c.json({ error: "No photo file provided" }, 400);
  }

  const ext = file.name?.split(".").pop()?.toLowerCase() || "jpg";
  const allowed = ["jpg", "jpeg", "png", "webp"];
  if (!allowed.includes(ext)) {
    return c.json({ error: "Only jpg, png, webp allowed" }, 400);
  }

  const dataDir = process.env.DB_PATH ? dirname(process.env.DB_PATH) : "./data";
  const photosDir = `${dataDir}/photos`;
  mkdirSync(photosDir, { recursive: true });

  try {
    const existing = readdirSync(photosDir).filter(f => f.startsWith(`asset-${id}-`));
    for (const old of existing) unlinkSync(`${photosDir}/${old}`);
  } catch {}

  const ts = Date.now();
  const filename = `asset-${id}-${ts}.${ext}`;
  const filepath = `${photosDir}/${filename}`;
  const buffer = await file.arrayBuffer();
  writeFileSync(filepath, Buffer.from(buffer));

  const photoUrl = `/api/photos/${filename}`;
  await db.update(assets).set({ photoUrl, updatedAt: new Date().toISOString() }).where(and(eq(assets.id, id), eq(assets.companyId, companyId)));

  return c.json({ photoUrl });
});

api.delete("/assets/:id", requireRole("admin"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const [asset] = await db.select().from(assets).where(and(eq(assets.id, id), eq(assets.companyId, companyId))).limit(1);
  if (asset?.photoUrl) {
    const dataDir = process.env.DB_PATH ? dirname(process.env.DB_PATH) : "./data";
    try {
      const existing = readdirSync(`${dataDir}/photos`).filter(f => f.startsWith(`asset-${id}-`));
      for (const old of existing) unlinkSync(`${dataDir}/photos/${old}`);
    } catch {}
  }
  await db.delete(assets).where(and(eq(assets.id, id), eq(assets.companyId, companyId)));
  return c.json({ ok: true });
});

// ── User Management (admin only) ────────────────────────────────
api.get("/users", requireRole("admin"), async (c) => {
  const currentUser = c.get("user");
  const companyId = getCompanyId(c);
  const whereClause = currentUser.role === "super_admin" ? undefined : eq(users.companyId, companyId);
  const rows = await db
    .select({
      id: users.id,
      username: users.username,
      displayName: users.displayName,
      role: users.role,
      companyId: users.companyId,
      isActive: users.isActive,
      createdAt: users.createdAt,
      lastLogin: users.lastLogin,
    })
    .from(users)
    .where(whereClause)
    .orderBy(users.displayName);
  return c.json(rows);
});

api.post("/users", requireRole("admin"), async (c) => {
  const currentUser = c.get("user");
  const { username, password, displayName, role, companyId } = await c.req.json();
  if (!username || !password || !displayName) {
    return c.json({ error: "All fields required" }, 400);
  }
  // Only super_admin can create super_admin users
  if (role === "super_admin" && currentUser.role !== "super_admin") {
    return c.json({ error: "Only super admins can create super admin users" }, 403);
  }
  const hash = bcrypt.hashSync(password, 10);
  const assignCompanyId = companyId || currentUser.companyId;
  const [row] = await db
    .insert(users)
    .values({
      username: username.toLowerCase().trim(),
      passwordHash: hash,
      displayName,
      role: role || "readonly",
      companyId: assignCompanyId,
    })
    .returning();
  return c.json({ id: row.id, username: row.username, displayName: row.displayName, role: row.role, companyId: row.companyId }, 201);
});

api.put("/users/:id", requireRole("admin"), async (c) => {
  const currentUser = c.get("user");
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const data = await c.req.json();
  // Don't allow password change through this endpoint
  delete data.passwordHash;
  delete data.password;
  // Only super_admin can set role to super_admin
  if (data.role === "super_admin" && currentUser.role !== "super_admin") {
    return c.json({ error: "Only super admins can assign super admin role" }, 403);
  }
  const whereClause = currentUser.role === "super_admin" ? eq(users.id, id) : and(eq(users.id, id), eq(users.companyId, companyId));
  const [row] = await db.update(users).set(data).where(whereClause).returning();
  return c.json({ id: row.id, username: row.username, displayName: row.displayName, role: row.role, companyId: row.companyId });
});

// ── Company Logo Upload ─────────────────────────────────────────
api.post("/logo", requireSuperAdmin(), async (c) => {
  const companyId = getCompanyId(c);
  const body = await c.req.parseBody();
  const file = body["logo"];

  if (!file || typeof file === "string") {
    return c.json({ error: "No logo file provided" }, 400);
  }

  const ext = file.name?.split(".").pop()?.toLowerCase() || "png";
  const allowed = ["jpg", "jpeg", "png", "webp", "svg"];
  if (!allowed.includes(ext)) {
    return c.json({ error: "Only jpg, png, webp, svg allowed" }, 400);
  }

  const dataDir = process.env.DB_PATH ? dirname(process.env.DB_PATH) : "./data";
  const photosDir = `${dataDir}/photos`;
  mkdirSync(photosDir, { recursive: true });

  const filename = `company-logo.${ext}`;
  const filepath = `${photosDir}/${filename}`;
  const buffer = await file.arrayBuffer();
  writeFileSync(filepath, Buffer.from(buffer));

  const logoUrl = `/api/photos/${filename}`;
  // Save to settings
  const result = await db.update(settings).set({ value: logoUrl }).where(and(eq(settings.key, "companyLogo"), eq(settings.companyId, companyId))).returning();
  if (result.length === 0) {
    await db.insert(settings).values({ key: "companyLogo", value: logoUrl, companyId });
  }

  return c.json({ logoUrl });
});

// ── Settings (super_admin only — company name is locked) ─────────
api.put("/settings", requireSuperAdmin(), async (c) => {
  const companyId = getCompanyId(c);
  const data = await c.req.json(); // { key: value, key: value, ... }
  for (const [key, value] of Object.entries(data)) {
    // Upsert: try update, if no rows affected then insert
    const result = await db.update(settings).set({ value: String(value) }).where(and(eq(settings.key, key), eq(settings.companyId, companyId))).returning();
    if (result.length === 0) {
      await db.insert(settings).values({ key, value: String(value), companyId });
    }
  }
  const rows = await db.select().from(settings).where(eq(settings.companyId, companyId));
  const obj: Record<string, string> = {};
  for (const r of rows) obj[r.key] = r.value;
  return c.json(obj);
});

// Admin reset password
api.post("/users/:id/reset-password", requireRole("admin"), async (c) => {
  const id = parseInt(c.req.param("id"));
  const { newPassword } = await c.req.json();
  if (!newPassword || newPassword.length < 6) {
    return c.json({ error: "Password must be at least 6 characters" }, 400);
  }
  const hash = bcrypt.hashSync(newPassword, 10);
  await db.update(users).set({ passwordHash: hash }).where(eq(users.id, id));
  return c.json({ ok: true });
});

// ── Companies (super_admin only) ────────────────────────────────
api.get("/companies", requireRole("admin"), async (c) => {
  const rows = await db.select().from(companies).orderBy(companies.name);
  return c.json(rows);
});

api.post("/companies", requireSuperAdmin(), async (c) => {
  const { name, shortName } = await c.req.json();
  if (!name) return c.json({ error: "Company name required" }, 400);
  const [row] = await db.insert(companies).values({ name, shortName }).returning();
  return c.json(row, 201);
});

api.put("/companies/:id", requireSuperAdmin(), async (c) => {
  const id = parseInt(c.req.param("id"));
  const data = await c.req.json();
  const [row] = await db.update(companies).set(data).where(eq(companies.id, id)).returning();
  return c.json(row);
});

export { api };
