import { dirname } from "path";

// ── S-09/S-10 FIX: Shared upload validator (magic bytes + size) ──
const MAX_UPLOAD = 5 * 1024 * 1024; // 5MB
const IMAGE_MAGIC: Record<string, number[][]> = {
  jpg:  [[0xFF, 0xD8, 0xFF]],
  jpeg: [[0xFF, 0xD8, 0xFF]],
  png:  [[0x89, 0x50, 0x4E, 0x47]],
  webp: [[0x52, 0x49, 0x46, 0x46]], // RIFF header (WebP)
};

function validateUpload(file: File, allowSvg = false): { ok: true; ext: string } | { ok: false; error: string } {
  if (file.size > MAX_UPLOAD) return { ok: false, error: "File too large — 5MB max" };
  const ext = file.name?.split(".").pop()?.toLowerCase() || "";
  const allowed = allowSvg ? ["jpg", "jpeg", "png", "webp", "svg"] : ["jpg", "jpeg", "png", "webp"];
  if (!allowed.includes(ext)) return { ok: false, error: `Only ${allowed.join(", ")} allowed` };
  return { ok: true, ext };
}

async function validateImageBytes(buffer: ArrayBuffer, ext: string): Promise<boolean> {
  if (ext === "svg") return true; // SVG is text-based, no magic bytes
  const bytes = new Uint8Array(buffer).slice(0, 8);
  const signatures = IMAGE_MAGIC[ext];
  if (!signatures) return false;
  return signatures.some(sig => sig.every((b, i) => bytes[i] === b));
}

const api = new Hono();

// ── Public Settings (no auth — needed on login page) ────────────
// Only expose safe display keys (company name, logo, theme) — never internal config
const PUBLIC_SETTINGS_KEYS = new Set(["companyName", "companyLogo", "theme", "accentColor"]);
api.get("/settings", async (c) => {
  const cid = parseInt(c.req.query("companyId") || "1");
  if (isNaN(cid) || cid < 1) return c.json({});
  const rows = await db.select().from(settings).where(eq(settings.companyId, cid));
  const obj: Record<string, string> = {};
  for (const r of rows) {
    if (PUBLIC_SETTINGS_KEYS.has(r.key)) obj[r.key] = r.value;
  }
  return c.json(obj);
});

// All remaining API routes require auth
api.use("/*", requireAuth);

