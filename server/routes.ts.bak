api.get("/companies", requireRole("admin"), async (c) => {
  const rows = await db.select().from(companies).orderBy(companies.name);
  return c.json(rows);
});

api.post("/companies", requireSuperAdmin(), async (c) => {
  const { name, shortName } = await c.req.json();
  if (!name) return c.json({ error: "Company name required" }, 400);
  const [row] = await db.insert(companies).values({ name, shortName }).returning();
  return c.json(row, 201);
});

api.put("/companies/:id", requireSuperAdmin(), async (c) => {
  const id = parseInt(c.req.param("id"));
  const data = await c.req.json();
  const [row] = await db.update(companies).set(data).where(eq(companies.id, id)).returning();
  return c.json(row);
});

export { api };
