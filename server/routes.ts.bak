// ── Job Budgets ─────────────────────────────────────────────────
api.put("/jobs/:jobId/budgets/:id", requireRole("admin", "pm"), validate(BudgetSchema), async (c) => {
  const companyId = getCompanyId(c);
  const jobId = parseInt(c.req.param("jobId"));
  const id = parseInt(c.req.param("id"));
  // Verify job belongs to this company
  const [job] = await db.select({ id: jobs.id }).from(jobs)
    .where(and(eq(jobs.id, jobId), eq(jobs.companyId, companyId))).limit(1);
  if (!job) return c.json({ error: "Job not found" }, 404);
  const data = c.get("validatedBody") || await c.req.json();
  const [row] = await db.update(jobBudgets).set(data).where(and(eq(jobBudgets.id, id), eq(jobBudgets.jobId, jobId))).returning();
  return c.json(row);
});

// ── Job Costs ───────────────────────────────────────────────────
api.post("/jobs/:jobId/costs", requireRole("admin", "pm"), validate(CostSchema), async (c) => {
  const companyId = getCompanyId(c);
  const jobId = parseInt(c.req.param("jobId"));
  // Verify job belongs to this company before allowing cost insert
  const [job] = await db.select({ id: jobs.id }).from(jobs)
    .where(and(eq(jobs.id, jobId), eq(jobs.companyId, companyId))).limit(1);
  if (!job) return c.json({ error: "Job not found" }, 404);
  const data = c.get("validatedBody") || await c.req.json();
  const [row] = await db.insert(jobCosts).values({ ...data, jobId }).returning();
  return c.json(row, 201);
});

// ── Job Assignments (the drag-and-drop core) ────────────────────
api.get("/assignments", async (c) => {
  const jobId = c.req.query("jobId");
  const activeOnly = c.req.query("active") !== "false";

  let condition = activeOnly ? eq(jobAssignments.isActive, true) : undefined;
  if (jobId) {
    const jid = parseInt(jobId);
    condition = activeOnly
      ? and(eq(jobAssignments.jobId, jid), eq(jobAssignments.isActive, true))
      : eq(jobAssignments.jobId, jid);
  }

  const rows = await db
    .select({
      id: jobAssignments.id,
      jobId: jobAssignments.jobId,
      employeeId: jobAssignments.employeeId,
      role: jobAssignments.role,
      billRate: jobAssignments.billRate,
      isActive: jobAssignments.isActive,
      assignedAt: jobAssignments.assignedAt,
      employeeFirstName: employees.firstName,
      employeeLastName: employees.lastName,
      employeeNumber: employees.employeeNumber,
      classificationName: classifications.name,
      classificationColor: classifications.color,
      department: classifications.department,
    })
    .from(jobAssignments)
    .leftJoin(employees, eq(jobAssignments.employeeId, employees.id))
    .leftJoin(classifications, eq(employees.classificationId, classifications.id))
    .where(condition);

  return c.json(rows);
});

// Assign employee to job (drag to job)
api.post("/assignments", requireRole("admin", "pm"), validate(AssignmentSchema), async (c) => {
  const { jobId, employeeId, role, billRate } = c.get("validatedBody") || await c.req.json();

  // Deactivate any current active assignments for this employee first
  await db.update(jobAssignments)
    .set({ isActive: false })
    .where(and(eq(jobAssignments.employeeId, employeeId), eq(jobAssignments.isActive, true)));

  // Check if assignment to this job already exists (reactivate it)
  const [existing] = await db
    .select()
    .from(jobAssignments)
    .where(and(eq(jobAssignments.jobId, jobId), eq(jobAssignments.employeeId, employeeId)))
    .limit(1);

  if (existing) {
    const [row] = await db
      .update(jobAssignments)
      .set({ isActive: true, role, billRate, assignedAt: new Date().toISOString() })
      .where(eq(jobAssignments.id, existing.id))
      .returning();
    return c.json(row);
  }

  const [row] = await db
    .insert(jobAssignments)
    .values({ jobId, employeeId, role, billRate })
    .returning();
  return c.json(row, 201);
});

// Unassign employee (drag back to bench)
api.delete("/assignments/:id", requireRole("admin", "pm"), async (c) => {
  const id = parseInt(c.req.param("id"));
  await db.update(jobAssignments).set({ isActive: false }).where(eq(jobAssignments.id, id));
  return c.json({ ok: true });
});

// Move employee between jobs
api.post("/assignments/move", requireRole("admin", "pm"), async (c) => {
  const { employeeId, fromJobId, toJobId } = await c.req.json();

  // Validate employee is actually active on fromJob
  const [current] = await db.select({ id: jobAssignments.id })
    .from(jobAssignments)
    .where(and(
      eq(jobAssignments.employeeId, employeeId),
      eq(jobAssignments.jobId, fromJobId),
      eq(jobAssignments.isActive, true)
    ))
    .limit(1);

  if (!current) {
    return c.json({ error: "Employee is not currently assigned to that job" }, 400);
  }

  // Deactivate old assignment
  await db
    .update(jobAssignments)
    .set({ isActive: false })
    .where(eq(jobAssignments.id, current.id));

  // Create or reactivate new assignment
  const [existing] = await db
    .select()
    .from(jobAssignments)
    .where(and(eq(jobAssignments.jobId, toJobId), eq(jobAssignments.employeeId, employeeId)))
    .limit(1);

  if (existing) {
    const [row] = await db
      .update(jobAssignments)
      .set({ isActive: true, assignedAt: new Date().toISOString() })
      .where(eq(jobAssignments.id, existing.id))
      .returning();
    return c.json(row);
  }

  const [row] = await db
    .insert(jobAssignments)
    .values({ jobId: toJobId, employeeId })
    .returning();
  return c.json(row, 201);
});

// ── Workforce Board aggregate (single call for the board) ───────
api.get("/workforce-board", async (c) => {
  const companyId = getCompanyId(c);
  // Get all active employees with classifications + photo
  const allEmployees = await db
    .select({
      id: employees.id,
      employeeNumber: employees.employeeNumber,
      firstName: employees.firstName,
      lastName: employees.lastName,
      classificationId: employees.classificationId,
      classificationName: classifications.name,
      classificationColor: classifications.color,
      department: classifications.department,
      hasLicense: classifications.hasLicense,
      status: employees.status,
      photoUrl: employees.photoUrl,
    })
    .from(employees)
    .leftJoin(classifications, eq(employees.classificationId, classifications.id))
    .where(and(eq(employees.companyId, companyId), eq(employees.status, "active")))
    .orderBy(classifications.name, employees.lastName);

  // Get all active assignments
  const activeAssignments = await db
    .select()
    .from(jobAssignments)
    .where(eq(jobAssignments.isActive, true));

  // Get active/planning jobs with budgets and jurisdictions (only showOnBoard)
  const activeJobs = await db
    .select({
      id: jobs.id,
      jobNumber: jobs.jobNumber,
      name: jobs.name,
      address: jobs.address,
      jurisdictionId: jobs.jurisdictionId,
      gcContact: jobs.gcContact,
      status: jobs.status,
      startDate: jobs.startDate,
      endDate: jobs.endDate,
      scopeOfWork: jobs.scopeOfWork,
      originalContract: jobs.originalContract,
      currentContract: jobs.currentContract,
      showOnBoard: jobs.showOnBoard,
      createdAt: jobs.createdAt,
      updatedAt: jobs.updatedAt,
      jurisdictionName: jurisdictions.name,
    })
    .from(jobs)
    .leftJoin(jurisdictions, eq(jobs.jurisdictionId, jurisdictions.id))
    .where(and(eq(jobs.companyId, companyId), sql`${jobs.status} IN ('planning', 'active') AND ${jobs.showOnBoard} = 1`))
    .orderBy(jobs.jobNumber);

  const budgets = await db.select().from(jobBudgets);

  // Get latest finance data from BOTH detail and summary records
  // Detail has: hour_budget, hours_used, labor/material/general budget+cost
  // Summary has: per-category curr_budget + cost_to_date (including equipment)
  // We pull detail for hours + material, and summary for equipment + general (more granular)
  const detailFinance = sqlite.query(`
    SELECT job_id, hour_budget, hours_used,
           material_budget, material_cost,
           general_budget, general_cost
    FROM project_finance_data
    WHERE (report_type = 'detail' OR report_type IS NULL)
      AND id IN (
        SELECT MAX(id) FROM project_finance_data
        WHERE report_type = 'detail' OR report_type IS NULL
        GROUP BY job_id
      )
  `).all() as any[];
  const summaryFinance = sqlite.query(`
    SELECT job_id,
           equipment_curr_budget, equipment_cost_to_date,
           general_curr_budget, general_cost_to_date
    FROM project_finance_data
    WHERE report_type = 'summary'
      AND id IN (
        SELECT MAX(id) FROM project_finance_data
        WHERE report_type = 'summary'
        GROUP BY job_id
      )
  `).all() as any[];
  const summaryMap = new Map<number, any>();
  for (const s of summaryFinance) {
    summaryMap.set(s.job_id, s);
  }
  const financeMap = new Map<number, any>();
  for (const f of detailFinance) {
    const s = summaryMap.get(f.job_id);
    financeMap.set(f.job_id, {
      hourBudget: f.hour_budget || 0,
      hoursUsed: f.hours_used || 0,
      materialBudget: f.material_budget || 0,
      materialCost: f.material_cost || 0,
      equipmentBudget: s?.equipment_curr_budget || 0,
      equipmentCost: s?.equipment_cost_to_date || 0,
      generalBudget: s?.general_curr_budget || f.general_budget || 0,
      generalCost: s?.general_cost_to_date || f.general_cost || 0,
    });
  }

  // Get all jurisdiction rates for quick lookup — build a map keyed by "jurId:classId"
  const allJurisdictionRates = await db.select().from(jurisdictionRates).where(eq(jurisdictionRates.companyId, companyId));
  const rateMap = new Map<string, { hourlyRate: number; totalCostRate: number }>();
  for (const r of allJurisdictionRates) {
    rateMap.set(`${Number(r.jurisdictionId)}:${Number(r.classificationId)}`, {
      hourlyRate: r.hourlyRate,
      totalCostRate: r.totalCostRate,
    });
  }

  // Build the board data
  const assignedEmployeeIds = new Set(activeAssignments.map((a) => a.employeeId));
  const bench = allEmployees.filter((e) => !assignedEmployeeIds.has(e.id));

  const jobCards = activeJobs.map((job) => {
    const jobAssigns = activeAssignments.filter((a) => a.jobId === job.id);
    const crew = jobAssigns.map((a) => {
      const emp = allEmployees.find((e) => e.id === a.employeeId);
      if (!emp) return null;

      // Look up jurisdiction-specific rate: job jurisdiction + employee classification
      let effectiveRate = 0;
      let effectiveHourly = 0;
      if (job.jurisdictionId && emp.classificationId) {
        const key = `${Number(job.jurisdictionId)}:${Number(emp.classificationId)}`;
        const jRate = rateMap.get(key);
        if (jRate) {
          effectiveHourly = jRate.hourlyRate;
          effectiveRate = jRate.totalCostRate;
        }
      }

      return {
        ...emp,
        assignmentId: a.id,
        role: a.role,
        billRate: a.billRate,
        effectiveHourlyRate: effectiveHourly,
        effectiveCostRate: effectiveRate,
      };
    }).filter(Boolean);

    const jobBudgetData = budgets.filter((b) => b.jobId === job.id);
    const totalBudget = jobBudgetData.reduce((s, b) => s + (b.currentBudget || 0), 0);
    const dailyLaborCost = crew.reduce((s, e: any) => s + (e.effectiveCostRate || 0) * 8, 0);
    const weeklyLaborCost = crew.reduce((s, e: any) => s + (e.effectiveCostRate || 0) * 40, 0);
    const compositeHourlyRate = crew.length > 0
      ? crew.reduce((s, e: any) => s + (e.effectiveHourlyRate || 0), 0) / crew.length
      : 0;

    // Licensed to non-licensed ratio
    const licensedCount = crew.filter((e: any) => e.hasLicense).length;
    const nonLicensedCount = crew.length - licensedCount;
    let licenseRatio = { licensed: 0, perNonLicensed: 0 };
    if (crew.length > 0) {
      if (licensedCount === 0) {
        licenseRatio = { licensed: 0, perNonLicensed: nonLicensedCount };
      } else {
        // Express as 1/X where X = non-licensed per licensed (up to 2 decimals)
        const ratio = nonLicensedCount / licensedCount;
        const rounded = Math.round(ratio * 100) / 100;
        licenseRatio = { licensed: 1, perNonLicensed: rounded };
      }
    }

    // Manhours remaining + burndown
    const finance = financeMap.get(job.id);
    const hoursRemaining = finance ? Math.max(0, finance.hourBudget - finance.hoursUsed) : null;
    const hourBudget = finance?.hourBudget || null;
    const hoursUsed = finance?.hoursUsed || null;
    const materialBudget = finance?.materialBudget || null;
    const materialCost = finance?.materialCost || null;
    const equipmentBudget = finance?.equipmentBudget || null;
    const equipmentCost = finance?.equipmentCost || null;
    const generalBudget = finance?.generalBudget || null;
    const generalCost = finance?.generalCost || null;

    // Weeks remaining: hoursRemaining / (crewCount * 40)
    const crewHoursPerWeek = crew.length * 40;
    const weeksRemaining = (hoursRemaining !== null && crewHoursPerWeek > 0)
      ? hoursRemaining / crewHoursPerWeek
      : null;

    // Estimated runout date
    let hoursRunOutDate: string | null = null;
    if (weeksRemaining !== null) {
      const now = new Date();
      now.setDate(now.getDate() + Math.round(weeksRemaining * 7));
      hoursRunOutDate = now.toISOString().split("T")[0]; // YYYY-MM-DD
    }

    return {
      ...job,
      crew,
      crewCount: crew.length,
      budgets: jobBudgetData,
      totalBudget,
      dailyLaborCost,
      weeklyLaborCost,
      compositeHourlyRate,
      licenseRatio,
      hoursRemaining,
      hourBudget,
      hoursUsed,
      materialBudget,
      materialCost,
      equipmentBudget,
      equipmentCost,
      generalBudget,
      generalCost,
      weeksRemaining,
      hoursRunOutDate,
    };
  });

  return c.json({ bench, jobs: jobCards });
});

// ── Jurisdictions ───────────────────────────────────────────────
api.get("/jurisdictions", async (c) => {
  const companyId = getCompanyId(c);
  const rows = await db.select().from(jurisdictions).where(eq(jurisdictions.companyId, companyId)).orderBy(jurisdictions.name);
  return c.json(rows);
});

api.post("/jurisdictions", requireRole("admin", "pm"), validate(JurisdictionSchema), async (c) => {
  const companyId = getCompanyId(c);
  const data = c.get("validatedBody") || await c.req.json();
  const [row] = await db.insert(jurisdictions).values({ ...data, companyId }).returning();
  return c.json(row, 201);
});

api.put("/jurisdictions/:id", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const data = await c.req.json();
  const [row] = await db.update(jurisdictions).set(data).where(and(eq(jurisdictions.id, id), eq(jurisdictions.companyId, companyId))).returning();
  return c.json(row);
});

api.delete("/jurisdictions/:id", requireRole("admin"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  // Delete associated rates first, then the jurisdiction
  await db.delete(jurisdictionRates).where(and(eq(jurisdictionRates.jurisdictionId, id), eq(jurisdictionRates.companyId, companyId)));
  await db.delete(jurisdictions).where(and(eq(jurisdictions.id, id), eq(jurisdictions.companyId, companyId)));
  return c.json({ ok: true });
});

// ── Jurisdiction Rates ─────────────────────────────────────────
api.get("/jurisdictions/:id/rates", async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const rows = await db
    .select({
      id: jurisdictionRates.id,
      jurisdictionId: jurisdictionRates.jurisdictionId,
      classificationId: jurisdictionRates.classificationId,
      hourlyRate: jurisdictionRates.hourlyRate,
      totalCostRate: jurisdictionRates.totalCostRate,
      effectiveDate: jurisdictionRates.effectiveDate,
      expirationDate: jurisdictionRates.expirationDate,
      classificationName: classifications.name,
      department: classifications.department,
      classificationColor: classifications.color,
    })
    .from(jurisdictionRates)
    .leftJoin(classifications, eq(jurisdictionRates.classificationId, classifications.id))
    .where(and(eq(jurisdictionRates.jurisdictionId, id), eq(jurisdictionRates.companyId, companyId)))
    .orderBy(classifications.department, classifications.name);
  return c.json(rows);
});

api.post("/jurisdictions/:id/rates", requireRole("admin", "pm"), validate(RateSchema), async (c) => {
