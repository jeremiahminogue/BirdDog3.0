// Upload employee photo
api.post("/employees/:id/photo", requireRole("admin", "pm"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const body = await c.req.parseBody();
  const file = body["photo"];

  if (!file || typeof file === "string") {
    return c.json({ error: "No photo file provided" }, 400);
  }

  // S-09/S-10: Validate size, extension, AND magic bytes
  const check = validateUpload(file as File);
  if (!check.ok) return c.json({ error: check.error }, 400);
  const ext = check.ext;

  const buffer = await (file as File).arrayBuffer();
  if (!await validateImageBytes(buffer, ext)) {
    return c.json({ error: "File content doesn't match its extension" }, 400);
  }

  const dataDir = process.env.DB_PATH ? dirname(process.env.DB_PATH) : "./data";
  const photosDir = `${dataDir}/photos`;
  mkdirSync(photosDir, { recursive: true });

  // Remove old photos for this employee
  try {
    const existing = readdirSync(photosDir).filter(f => f.startsWith(`emp-${id}-`) || f === `emp-${id}.${ext}`);
    for (const old of existing) unlinkSync(`${photosDir}/${old}`);
  } catch {}

  const ts = Date.now();
  const filename = `emp-${id}-${ts}.${ext}`;
  const filepath = `${photosDir}/${filename}`;
  writeFileSync(filepath, Buffer.from(buffer));

  const photoUrl = `/api/photos/${filename}`;
  await db.update(employees).set({ photoUrl, updatedAt: new Date().toISOString() }).where(and(eq(employees.id, id), eq(employees.companyId, companyId)));

  return c.json({ photoUrl });
});

// Toggle employee active/inactive
api.put("/employees/:id/status", requireRole("admin"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const { status, reasonForLeaving } = await c.req.json() as {
    status: "active" | "inactive";
    reasonForLeaving?: string;
  };

  if (!["active", "inactive"].includes(status)) {
    return c.json({ error: "Status must be 'active' or 'inactive'" }, 400);
  }

  const updates: any = { status, updatedAt: new Date().toISOString() };

  if (status === "inactive" && reasonForLeaving !== undefined) {
    updates.reasonForLeaving = reasonForLeaving || null;
  }

  // If reactivating, clear reason for leaving
  if (status === "active") {
    updates.reasonForLeaving = null;
  }

  const [row] = await db.update(employees).set(updates)
    .where(and(eq(employees.id, id), eq(employees.companyId, companyId)))
    .returning();

  // If deactivating, also deactivate their job assignments
  if (status === "inactive") {
    await db.update(jobAssignments)
      .set({ isActive: false })
      .where(and(eq(jobAssignments.employeeId, id), eq(jobAssignments.isActive, true)));
  }

  return c.json(row);
});

// Delete employee — only allowed if no history (assignments, logs, etc.)
api.delete("/employees/:id", requireRole("admin"), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));

  // Check for any related records (B-05: check ALL FK references)
  const assignments = sqlite.query(
    "SELECT COUNT(*) as c FROM job_assignments WHERE employee_id = ?"
  ).get(id) as any;
  const logs = sqlite.query(
    "SELECT COUNT(*) as c FROM daily_log WHERE employee_id = ?"
  ).get(id) as any;
  const notes = sqlite.query(
    "SELECT COUNT(*) as c FROM employee_notes WHERE employee_id = ?"
  ).get(id) as any;
  const opps = sqlite.query(
    "SELECT COUNT(*) as c FROM opportunities WHERE estimator_id = ?"
  ).get(id) as any;
  const actionItems = sqlite.query(
    "SELECT COUNT(*) as c FROM action_items WHERE assigned_to_id = ?"
  ).get(id) as any;
  const certs = sqlite.query(
    "SELECT COUNT(*) as c FROM certifications WHERE employee_id = ?"
  ).get(id) as any;
  const assetRefs = sqlite.query(
    "SELECT COUNT(*) as c FROM assets WHERE assigned_to_employee = ?"
  ).get(id) as any;
  const pendingMoves = sqlite.query(
    "SELECT COUNT(*) as c FROM scheduled_moves WHERE employee_id = ?"
  ).get(id) as any;

  const total = (assignments?.c || 0) + (logs?.c || 0) + (notes?.c || 0) + (opps?.c || 0)
    + (actionItems?.c || 0) + (certs?.c || 0) + (assetRefs?.c || 0) + (pendingMoves?.c || 0);
  if (total > 0) {
    return c.json({
      error: "Cannot delete — this employee has history. Deactivate them instead.",
      details: {
        assignments: assignments?.c || 0,
        dailyLogs: logs?.c || 0,
        notes: notes?.c || 0,
        opportunities: opps?.c || 0,
        actionItems: actionItems?.c || 0,
        certifications: certs?.c || 0,
        assignedAssets: assetRefs?.c || 0,
        scheduledMoves: pendingMoves?.c || 0,
      }
    }, 400);
  }

  await db.delete(employees).where(and(eq(employees.id, id), eq(employees.companyId, companyId)));
  return c.json({ ok: true });
});

// ── Jobs ────────────────────────────────────────────────────────
api.get("/jobs", async (c) => {
  const companyId = getCompanyId(c);
  const status = c.req.query("status");
  const condition = status ? and(eq(jobs.companyId, companyId), eq(jobs.status, status as any)) : eq(jobs.companyId, companyId);
  const rows = await db.select().from(jobs).where(condition).orderBy(jobs.jobNumber);
  return c.json(rows);
});

api.get("/jobs/:id", async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const [job] = await db.select().from(jobs).where(and(eq(jobs.id, id), eq(jobs.companyId, companyId))).limit(1);
  if (!job) return c.json({ error: "Not found" }, 404);

  const budgets = await db.select().from(jobBudgets).where(eq(jobBudgets.jobId, id));
  const costs = await db.select().from(jobCosts).where(eq(jobCosts.jobId, id)).orderBy(desc(jobCosts.dateRecorded));
  const subs = await db.select().from(subcontracts).where(eq(subcontracts.jobId, id));

  return c.json({ ...job, budgets, costs, subcontracts: subs });
});

api.post("/jobs", requireRole("admin", "pm"), validate(JobSchema), async (c) => {
  const companyId = getCompanyId(c);
  const data = c.get("validatedBody") || await c.req.json();
  const [row] = await db.insert(jobs).values({ ...data, companyId }).returning();

  // Auto-create budget categories
  const categories = ["labor", "material", "equipment", "general", "subcontract"] as const;
  for (const cat of categories) {
    await db.insert(jobBudgets).values({ jobId: row.id, category: cat });
  }

  return c.json(row, 201);
});

api.put("/jobs/:id", requireRole("admin", "pm"), validate(JobSchema), async (c) => {
  const companyId = getCompanyId(c);
  const id = parseInt(c.req.param("id"));
  const data = c.get("validatedBody") || await c.req.json();
  data.updatedAt = new Date().toISOString();
  // Ensure jurisdictionId is stored as integer or null (not string "null")
  if (data.jurisdictionId !== undefined) {
    data.jurisdictionId = data.jurisdictionId ? parseInt(data.jurisdictionId) : null;
  }
  const [row] = await db.update(jobs).set(data).where(and(eq(jobs.id, id), eq(jobs.companyId, companyId))).returning();
  return c.json(row);
});

